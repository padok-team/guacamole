{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>padok-team/renovate-config"
  ],

  "platformAutomerge": false,
  "automergeType": "pr",

  "packageRules": [
    {
      "description": "Automerge safe updates: digests and patches",
      "matchUpdateTypes": ["digest", "patch"],
      "automerge": true,
      "automergeType": "pr",
      "groupName": "safe updates"
    },
    {
      "description": "Go updates",
      "matchManagers": ["gomod"],
      "groupName": "go dependencies",
      "postUpdateOptions": ["gomodTidy"]
    },
    {
      "description": "Docker image updates",
      "matchManagers": ["dockerfile"],
      "groupName": "docker images"
    },
    {
      "description": "GitHub Actions updates",
      "matchManagers": ["github-actions"],
      "groupName": "github actions"
    },
    {
      "description": "Minor updates: review before merge",
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "schedule": ["before 10am on monday"]
    },
    {
      "description": "Major updates: manual approval before PR creation",
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "dependencyDashboardApproval": true
    },
    {
      "description": "CLI tool versions",
      "matchManagers": ["asdf"],
      "groupName": "cli tools"
    }
  ]
}
